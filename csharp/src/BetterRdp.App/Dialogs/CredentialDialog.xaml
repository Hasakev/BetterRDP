<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="BetterRdp_App.Dialogs.CredentialDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Add credential"
    PrimaryButtonText="Add"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    mc:Ignorable="d">

    <StackPanel Spacing="12" Width="340">
        <TextBox x:Name="UsernameInput" Header="Username" />
        <TextBox x:Name="DomainInput" Header="Domain" PlaceholderText="optional" />
        <PasswordBox x:Name="PasswordInput" Header="Password" />
    </StackPanel>
</ContentDialog>
